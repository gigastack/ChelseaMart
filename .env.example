# Template only. Copy this file to `.env.local` in the active worktree for real local runtime config.
NEXT_PUBLIC_SITE_URL=https://mart.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Shared/session pooler example for IPv4-friendly local migrations. Use direct connection on IPv6-capable networks.
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-1-region.pooler.supabase.com:5432/postgres

# Optional bootstrap only. Runtime admin authorization should come from persisted RBAC profiles.
ADMIN_EMAILS=owner@example.com,ops@example.com
DEMO_ADMIN_EMAIL=demo.admin@mart.local
DEMO_ADMIN_PASSWORD=DemoAdmin123!
DEMO_CUSTOMER_EMAIL=demo.customer@mart.local
DEMO_CUSTOMER_PASSWORD=DemoCustomer123!

ELIM_API_BASE_URL=https://api.elim.asia/v1
ELIM_API_KEY=your-elim-bearer-key

PAYSTACK_API_BASE_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=your-paystack-secret-key
# Optional. If blank, webhook verification falls back to PAYSTACK_SECRET_KEY.
PAYSTACK_WEBHOOK_SECRET=

# App-owned transactional email. Supabase Auth still owns signup/reset email delivery for now.
EMAIL_PROVIDER=supabase
EMAIL_FROM=noreply@mart.example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
